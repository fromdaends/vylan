# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# Claude Code internals — local worktrees the agent uses for parallel
# tasks. Never meant to be tracked.
.claude/worktrees/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# supabase local stack
/supabase/.branches/
/supabase/.temp/
/supabase/seed_local.sql

# test artifacts
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
# Playwright MCP server scratch output (console logs + page snapshots)
.playwright-mcp/

# Python bytecode (from .claude/skills/ tooling scripts)
__pycache__/
*.pyc

# Windows folder metadata
desktop.ini

# Local-only scratch folders (founder's test docs + agent uploads) — never tracked
/CLAUDE UPLOADS/
/VYLAN TESTS/


# Local ad/marketing assets (not part of the app)
.vylan-ad/
