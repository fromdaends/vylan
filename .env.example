# Vylan — environment template.
# Copy to .env.local and fill in real values. NEVER commit .env.local.

# --- Supabase ---------------------------------------------------------------
# Local dev: run `npx supabase start` and copy the printed URL + anon key.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Google OAuth: no app env vars needed. The Client ID + Secret live in
# the Supabase dashboard (Authentication → Providers → Google). The
# "Continue with Google" button on /login + /signup will return a
# Supabase error until that provider is enabled.

# --- App --------------------------------------------------------------------
APP_URL=http://localhost:3000
CRON_SECRET=replace-me-with-a-32-char-random-string

# --- Email (Resend) ---------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@vylan.app

# --- SMS (Twilio) -----------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- AI (Anthropic) ---------------------------------------------------------
ANTHROPIC_API_KEY=

# --- AI provider switch -----------------------------------------------------
# Which model runs the document classifier. Default = Anthropic (Claude Sonnet).
# Set to "openai" to use GPT-5 (gpt-5.4 by default, see OPENAI_MODEL below)
# instead. Requires OPENAI_API_KEY below.
# Flip back to Claude anytime by clearing this or setting it to "anthropic".
AI_CLASSIFIER_PROVIDER=
# OpenAI key — only needed when AI_CLASSIFIER_PROVIDER=openai.
OPENAI_API_KEY=
# Optional overrides (sensible defaults when blank):
#   OPENAI_MODEL            — defaults to gpt-5.4 (cheapest GPT-5 with full-fidelity
#                             vision). gpt-5.4-mini = cheaper, gpt-5.5 = newer/pricier.
#   OPENAI_REASONING_EFFORT — minimal | low | medium | high, defaults to low
OPENAI_MODEL=
OPENAI_REASONING_EFFORT=

# --- Billing (Stripe — test mode for now) -----------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Signing secret for the SEPARATE Stripe Connect webhook endpoint
# (/api/billing/connect/webhook) — the one that tracks each accountant's
# connected-account status and (later) client payments. This is a DIFFERENT
# value than STRIPE_WEBHOOK_SECRET above; copy it from the Connect webhook you
# add in the Stripe Dashboard. Leave blank until you create that endpoint.
STRIPE_CONNECT_WEBHOOK_SECRET=
STRIPE_PRICE_SOLO=
STRIPE_PRICE_CABINET=
STRIPE_PRICE_CABINET_PLUS=
# Set to "true" ONLY after enabling Stripe Tax in the Stripe Dashboard and
# adding your GST + QST registrations. Turns on automatic GST/QST on self-serve
# checkout. Leave blank until then — enabling it before Stripe Tax is configured
# makes every checkout error out. (Manual dashboard subscriptions/invoices get
# tax from the dashboard's automatic-tax toggle, independent of this flag.)
STRIPE_TAX_ENABLED=

# --- PayPal (Commerce Platform, partner model) — SANDBOX --------------------
# Lets accountants connect their own PayPal Business account (Partner Referrals)
# so clients can pay them directly through PayPal, alongside Stripe. Vylan never
# holds funds and takes no fee on either rail.
#
# How to get these (sandbox):
#   1. developer.paypal.com -> Apps & Credentials -> (Sandbox) -> Create App.
#   2. Copy the app's Client ID + Secret below.
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# Sandbox vs live switch. Live requires exactly "live" (or "production") AND
# production partner credentials from PayPal's partner program (approval
# pending). Anything else fails safe to sandbox, so real money can never be
# touched by accident.
PAYPAL_ENVIRONMENT=sandbox
# OUR PayPal account's merchant id (the platform/partner "payer id") — required
# to verify a connected seller via the merchant-integrations API. Sandbox: the
# Account ID of the app-owner business account (developer.paypal.com -> Testing
# Tools -> Sandbox Accounts -> the DEFAULT business account -> View/Edit ->
# Account ID). Live: our real account's merchant id, at partner approval.
PAYPAL_PARTNER_MERCHANT_ID=
# The BN code PayPal issues at partner onboarding. Blank in sandbox (the
# partner application is pending); attached to API calls when set.
PAYPAL_PARTNER_ATTRIBUTION_ID=
# Webhook verification id: on the PayPal app page (developer dashboard), add a
# webhook pointing at https://<domain>/api/billing/paypal/webhook subscribed to
# PAYMENT.CAPTURE.COMPLETED, PAYMENT.CAPTURE.DENIED, PAYMENT.CAPTURE.PENDING,
# CHECKOUT.ORDER.APPROVED, MERCHANT.ONBOARDING.COMPLETED and
# MERCHANT.PARTNER-CONSENT.REVOKED, then paste the Webhook ID it shows here.
# Without it the webhook endpoint refuses deliveries (503) — payments still
# work through capture + the self-healing reconcile; this is the backstop.
PAYPAL_WEBHOOK_ID=

# --- E-signatures (SignWell) ------------------------------------------------
# Embedded e-signatures. Get a TEST-mode API key from your SignWell account
# (Settings -> API) and paste it here. Server-only secret; never exposed to the
# browser. Until this is set, "Request a signature" still creates the checklist
# item but shows "Signing setup needed".
SIGNWELL_API_KEY=
# Test vs live switch. Signing is TEST mode (watermarked, free, NOT legally
# binding) unless this is exactly "false". Leave blank/"true" while building;
# set to "false" to create real, legally-binding signatures (counts against your
# SignWell plan). This is the ONLY change needed to go live — no code change.
SIGNWELL_TEST_MODE=true
# Webhook verification. Create a webhook in SignWell (Settings -> API -> Webhooks)
# pointing at https://<your-domain>/api/signwell/webhook, then paste the
# "Webhook ID" it shows here. It's the key we use to verify each event is really
# from SignWell. Optional for testing (completion also self-heals when the
# accountant opens the engagement), required for real-time updates in production.
SIGNWELL_WEBHOOK_ID=
# "Place the signature anywhere" (embedded requesting). Create an API Application
# in SignWell (Settings -> API -> Applications), allow your Vylan domains
# (http://localhost:3000 for dev + your production URL), and paste its
# "API Application ID" here. When set, requesting a signature opens SignWell's
# editor so the accountant drops the signature field on any page before it's sent.
# Leave blank to keep the current behavior (a signature page auto-appended at the
# end). Purely additive — nothing breaks while it's unset.
SIGNWELL_API_APPLICATION_ID=

# --- Rate limiting (Upstash Redis) ------------------------------------------
# Required in production. Without these, rate limiters silently no-op
# (every request passes) — fine for local dev, dangerous in prod.
# Create a free Redis DB at https://upstash.com and paste the REST URL + token.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Demo booking (cal.com) -------------------------------------------------
# cal.com username (or team/event-slug path) used by /demo. If unset,
# the booking step shows a fallback link so prospects can still book.
# Example: NEXT_PUBLIC_CALCOM_LINK=vylan.app
NEXT_PUBLIC_CALCOM_LINK=vylan.app

# Inbox that receives founder notifications from /demo (new lead,
# qualified lead, booking confirmed). Defaults to hello@vylan.app.
FOUNDER_NOTIFY_EMAIL=

# --- Notion lead sync -------------------------------------------------------
# When set, every demo lead is mirrored as a page in a Notion database
# (one-way: form data goes to Notion; founder owns status + notes there).
# Both must be set for the push to run — if either is missing the lead
# still saves to Supabase but isn't synced.
#
# How to get these:
#   1. notion.com/profile/integrations -> + New integration -> "Vylan leads".
#      Copy the "Internal Integration Token" (starts with secret_...).
#   2. In your Notion workspace, open the leads database -> ... menu ->
#      Connections -> add the "Vylan leads" integration.
#   3. Database ID is the 32-char hex string in the database URL between
#      the slug and the ?. Hyphens optional.
NOTION_API_KEY=
NOTION_LEADS_DB_ID=

# --- QuickBooks (Intuit) — Stage 1: connection only, SANDBOX --------------
# Lets an accountant connect their QuickBooks Online (Intuit) company to Vylan
# via OAuth. This stage only stores + shows the connection; it does NOT read
# financial data, write transactions, or touch documents.
#
# How to get these:
#   1. developer.intuit.com -> sign in -> Dashboard -> create an app, choosing
#      the "QuickBooks Online and Payments" / Accounting scope.
#   2. Open the app -> "Keys & credentials" -> the DEVELOPMENT (sandbox) keys.
#      Copy the Client ID + Client Secret below.
#   3. Same app settings -> "Redirect URIs" -> add BOTH of these EXACTLY:
#        http://localhost:3000/api/integrations/quickbooks/callback
#        https://YOUR-VERCEL-DOMAIN/api/integrations/quickbooks/callback
QBO_CLIENT_ID=
QBO_CLIENT_SECRET=
# Sandbox vs production switch. Leave blank/"sandbox" while building; set to
# exactly "production" only after Intuit approves the app for production. Fails
# safe to sandbox, so we can never accidentally hit a real QuickBooks company.
QBO_ENVIRONMENT=sandbox
# Must match a Redirect URI registered in the Intuit app EXACTLY. When blank it
# falls back to APP_URL + /api/integrations/quickbooks/callback.
QBO_REDIRECT_URI=
# Tax-line posting kill-switch. Leave blank/OFF until the tax math is verified on
# a real Canadian QuickBooks company (the US sandbox can't validate GST/QST). When
# OFF, posted Bills/Invoices record the gross total with no tax code (today's
# behavior). Set to exactly "true" to post the pre-tax amount + the approved tax
# code and let QuickBooks compute GST/QST. Fails safe to OFF.
QBO_TAX_LINES_ENABLED=
# Encrypts the stored QuickBooks OAuth tokens at rest (AES-256-GCM), for the
# production go-live. A 32-byte key, base64 or hex. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Leave blank to keep tokens as today (plaintext, service-role-read-only). Apply
# migration 0480 BEFORE setting this. Once set, tokens re-encrypt on their next
# refresh. Losing/rotating this key makes existing connections unreadable (they
# just need to reconnect), so store it safely.
QBO_TOKEN_ENC_KEY=

# ── Xero (per-client bookkeeping, mirrors QuickBooks) ────────────────────────
# Create the app at https://developer.xero.com -> My Apps -> New app:
#   * App name: anything WITHOUT the word "Xero" (their rule)
#   * Integration type: Web app
#   * Company URL: https://vylan.app
#   * Redirect URI: https://vylan.app/api/integrations/xero/callback
#     (add http://localhost:3000/api/integrations/xero/callback for dev)
# Copy the Client ID; click "Generate a secret" (shown ONCE). No sandbox/prod
# split — the free "Demo Company" org is the test target. Free tier allows 5
# connected organisations; the 6th needs the paid Core tier.
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
# Must match a Redirect URI registered on the Xero app EXACTLY. When blank it
# falls back to APP_URL + /api/integrations/xero/callback.
XERO_REDIRECT_URI=
