# Vylan — environment template.
# Copy to .env.local and fill in real values. NEVER commit .env.local.

# --- Supabase ---------------------------------------------------------------
# Local dev: run `npx supabase start` and copy the printed URL + anon key.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Google OAuth: no app env vars needed. The Client ID + Secret live in
# the Supabase dashboard (Authentication → Providers → Google). The
# "Continue with Google" button on /login + /signup will return a
# Supabase error until that provider is enabled.

# --- App --------------------------------------------------------------------
APP_URL=http://localhost:3000
CRON_SECRET=replace-me-with-a-32-char-random-string

# --- Email (Resend) ---------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@vylan.app

# --- SMS (Twilio) -----------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# --- AI (Anthropic) ---------------------------------------------------------
ANTHROPIC_API_KEY=

# --- AI provider switch -----------------------------------------------------
# Which model runs the document classifier. Default = Anthropic (Claude Sonnet).
# Set to "openai" to use GPT-5 (gpt-5.4 by default, see OPENAI_MODEL below)
# instead. Requires OPENAI_API_KEY below.
# Flip back to Claude anytime by clearing this or setting it to "anthropic".
AI_CLASSIFIER_PROVIDER=
# OpenAI key — only needed when AI_CLASSIFIER_PROVIDER=openai.
OPENAI_API_KEY=
# Optional overrides (sensible defaults when blank):
#   OPENAI_MODEL            — defaults to gpt-5.4 (cheapest GPT-5 with full-fidelity
#                             vision). gpt-5.4-mini = cheaper, gpt-5.5 = newer/pricier.
#   OPENAI_REASONING_EFFORT — minimal | low | medium | high, defaults to low
OPENAI_MODEL=
OPENAI_REASONING_EFFORT=

# --- Billing (Stripe — test mode for now) -----------------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Signing secret for the SEPARATE Stripe Connect webhook endpoint
# (/api/billing/connect/webhook) — the one that tracks each accountant's
# connected-account status and (later) client payments. This is a DIFFERENT
# value than STRIPE_WEBHOOK_SECRET above; copy it from the Connect webhook you
# add in the Stripe Dashboard. Leave blank until you create that endpoint.
STRIPE_CONNECT_WEBHOOK_SECRET=
STRIPE_PRICE_SOLO=
STRIPE_PRICE_CABINET=
STRIPE_PRICE_CABINET_PLUS=
# Set to "true" ONLY after enabling Stripe Tax in the Stripe Dashboard and
# adding your GST + QST registrations. Turns on automatic GST/QST on self-serve
# checkout. Leave blank until then — enabling it before Stripe Tax is configured
# makes every checkout error out. (Manual dashboard subscriptions/invoices get
# tax from the dashboard's automatic-tax toggle, independent of this flag.)
STRIPE_TAX_ENABLED=

# --- E-signatures (SignWell) ------------------------------------------------
# Embedded e-signatures. Get a TEST-mode API key from your SignWell account
# (Settings -> API) and paste it here. Server-only secret; never exposed to the
# browser. Until this is set, "Request a signature" still creates the checklist
# item but shows "Signing setup needed".
SIGNWELL_API_KEY=
# Test vs live switch. Signing is TEST mode (watermarked, free, NOT legally
# binding) unless this is exactly "false". Leave blank/"true" while building;
# set to "false" to create real, legally-binding signatures (counts against your
# SignWell plan). This is the ONLY change needed to go live — no code change.
SIGNWELL_TEST_MODE=true

# --- Rate limiting (Upstash Redis) ------------------------------------------
# Required in production. Without these, rate limiters silently no-op
# (every request passes) — fine for local dev, dangerous in prod.
# Create a free Redis DB at https://upstash.com and paste the REST URL + token.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Demo booking (cal.com) -------------------------------------------------
# cal.com username (or team/event-slug path) used by /demo. If unset,
# the booking step shows a fallback link so prospects can still book.
# Example: NEXT_PUBLIC_CALCOM_LINK=vylan.app
NEXT_PUBLIC_CALCOM_LINK=vylan.app

# Inbox that receives founder notifications from /demo (new lead,
# qualified lead, booking confirmed). Defaults to hello@vylan.app.
FOUNDER_NOTIFY_EMAIL=

# --- Notion lead sync -------------------------------------------------------
# When set, every demo lead is mirrored as a page in a Notion database
# (one-way: form data goes to Notion; founder owns status + notes there).
# Both must be set for the push to run — if either is missing the lead
# still saves to Supabase but isn't synced.
#
# How to get these:
#   1. notion.com/profile/integrations -> + New integration -> "Vylan leads".
#      Copy the "Internal Integration Token" (starts with secret_...).
#   2. In your Notion workspace, open the leads database -> ... menu ->
#      Connections -> add the "Vylan leads" integration.
#   3. Database ID is the 32-char hex string in the database URL between
#      the slug and the ?. Hyphens optional.
NOTION_API_KEY=
NOTION_LEADS_DB_ID=
